# NEXTAUTH_URL : 배포하는 서버의 url/api/auth eg) http://<host>:3000/api/auth
NODE_ENV=development
# NEXTAUTH_SECRET=<your-nextauth-secret>

# JWT 서명 키 (app/services/util/jwt.ts에서 사용 — 미설정 시 토큰 발급/검증 실패)
JWT_SECRET=<your-jwt-secret>

# PostgreSQL 연결 문자열 (Prisma datasource)
DB_URL="postgresql://<user>:<password>@<host>:5432/<database>?sslmode=require"

# 백엔드 API 엔드포인트
NEXT_PUBLIC_API_URL=http://<backend-host>:8124
NEXT_PUBLIC_SITE_URL=http://<frontend-host>:13030
NEXT_PUBLIC_DATA_API_URL=http://<backend-host>:8123

# Python API 서버
NEXT_PUBLIC_PYTHON_URL=http://<python-host>:8000
